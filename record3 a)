mysql> select * from tchr;
Empty set (0.00 sec)


2)ROLLBACK

mysql> insert into tchr(Id,name,salary)values(2,'Sneha',6000);
Query OK, 1 row affected (0.00 sec)

mysql> select * from tchr;
+----+-------+--------+
| Id | name  | salary |
+----+-------+--------+
|  2 | Sneha |   6000 |
+----+-------+--------+
1 row in set (0.00 sec)

mysql> rollback;
Query OK, 0 rows affected (0.05 sec)

mysql> select * from tchr;
Empty set (0.00 sec)

--------------------------

Database changed
mysql> set autocommit=0;
Query OK, 0 rows affected (0.00 sec)

mysql> insert into tchr values(3,'Indu',40000);
Query OK, 1 row affected (0.00 sec)

mysql> insert into tchr values(4,'Bindu',25000);
Query OK, 1 row affected (0.00 sec)

mysql> SAVEPOINT sp1;
Query OK, 0 rows affected (0.00 sec)


mysql> select * from tchr;
+----+-------+--------+
| Id | name  | salary |
+----+-------+--------+
|  3 | Indu  |  40000 |
|  4 | Bindu |  25000 |
+----+-------+--------+
2 rows in set (0.00 sec)

mysql> UPDATE tchr SET salary=35000 WHERE Id=3;
Query OK, 1 row affected (0.00 sec)
Rows matched: 1  Changed: 1  Warnings: 0

mysql> select * from tchr;
