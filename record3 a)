|  4 | Bindu   |  25000 |
|  5 | Lakshmi |   7600 |
+----+---------+--------+
3 rows in set (0.00 sec)

mysql> ROLLBACK TO sp1;
Query OK, 0 rows affected (0.00 sec)

mysql> select * from tchr;
