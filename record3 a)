| Id | name  | salary |
+----+-------+--------+
|  3 | Indu  |  35000 |
|  4 | Bindu |  25000 |
+----+-------+--------+
2 rows in set (0.00 sec)


mysql> SAVEPOINT sp2;
Query OK, 0 rows affected (0.00 sec)

mysql> insert into tchr values(5,'Lakshmi',7600);
Query OK, 1 row affected (0.00 sec)

mysql> SAVEPOINT sp3;
Query OK, 0 rows affected (0.00 sec)

mysql> DELETE FROM tchr WHERE Id =3;
Query OK, 1 row affected (0.00 sec)

mysql> select * from tchr;
+----+---------+--------+
| Id | name    | salary |
+----+---------+--------+
|  4 | Bindu   |  25000 |
|  5 | Lakshmi |   7600 |
